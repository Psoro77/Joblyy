# LLM provider: "ollama" (local) or "cloud" (via LiteLLM)
LLM_PROVIDER=ollama

# Ollama settings
OLLAMA_MODEL=gemma3:4b
OLLAMA_BASE_URL=http://localhost:11434

# Cloud provider settings (used when LLM_PROVIDER=cloud)
# Model format follows LiteLLM conventions, e.g. "anthropic/claude-sonnet-4-20250514"
CLOUD_API_KEY=
CLOUD_MODEL=anthropic/claude-sonnet-4-20250514
